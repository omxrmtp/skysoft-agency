# ===================================================================
# SkySoft API - .htaccess Configuration
# ===================================================================

# Enable URL rewriting
RewriteEngine On

# Set the base directory
RewriteBase /api

# ===================================================================
# Security Headers
# ===================================================================

# Protect against XSS attacks
<IfModule mod_headers.c>
    Header always set X-XSS-Protection "1; mode=block"
    Header always set X-Content-Type-Options nosniff
    Header always set X-Frame-Options DENY
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (basic)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'"
    
    # CORS headers (handled by PHP middleware, but backup here)
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
    Header always set Access-Control-Max-Age "3600"
</IfModule>

# ===================================================================
# File Security
# ===================================================================

# Deny access to sensitive files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "(^#.*#|~$|\.bak|\.conf|\.log|\.sql|\.env)">
    Require all denied
</FilesMatch>

# Deny access to config files
<FilesMatch "^(config|database|\.env)">
    Require all denied
</FilesMatch>

# Allow only specific file types in uploads
<Directory "uploads">
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg)$">
        Require all granted
    </FilesMatch>
    <FilesMatch ".*">
        Require all denied
    </FilesMatch>
</Directory>

# ===================================================================
# PHP Settings
# ===================================================================

# PHP version (uncomment and adjust as needed)
# AddHandler application/x-httpd-php82 .php

# Increase upload limits
php_value upload_max_filesize 10M
php_value post_max_size 10M
php_value max_execution_time 300
php_value max_input_time 300

# Error reporting (adjust for production)
php_value display_errors 0
php_value log_errors 1
php_value error_log logs/php_errors.log

# Session settings
php_value session.cookie_httponly 1
php_value session.cookie_secure 0
php_value session.use_strict_mode 1
php_value session.cookie_samesite Strict

# ===================================================================
# URL Rewriting Rules
# ===================================================================

# Handle preflight OPTIONS requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ index.php [QSA,L]

# Redirect all requests to index.php (API Gateway)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# ===================================================================
# Compression
# ===================================================================

# Enable gzip compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>

# ===================================================================
# Caching
# ===================================================================

# Set cache control headers for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # Fonts
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    
    # CSS and JS
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # JSON API responses (shorter cache)
    ExpiresByType application/json "access plus 5 minutes"
</IfModule>

# ===================================================================
# Rate Limiting (basic)
# ===================================================================

# Note: For advanced rate limiting, use PHP middleware or external services
<IfModule mod_reqtimeout.c>
    RequestReadTimeout header=20-40,MinRate=500 body=10,MinRate=500
</IfModule>

# ===================================================================
# Environment-specific Settings
# ===================================================================

# Development environment
<If "%{ENV:APP_ENV} == 'development'">
    php_value display_errors 1
    php_value error_reporting E_ALL
</IfModule>

# Production environment
<If "%{ENV:APP_ENV} == 'production'">
    php_value display_errors 0
    php_value error_reporting E_ALL & ~E_DEPRECATED & ~E_STRICT
    
    # Additional security headers for production
    <IfModule mod_headers.c>
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS
    </IfModule>
</IfModule>

# ===================================================================
# Custom Error Pages
# ===================================================================

# ErrorDocument 404 /api/error/404
# ErrorDocument 500 /api/error/500
# ErrorDocument 403 /api/error/403
# ErrorDocument 401 /api/error/401

# ===================================================================
# Logging
# ===================================================================

# Custom log format for API requests
<IfModule mod_log_config.c>
    LogFormat "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\" \"%{Authorization}i\"" api_log
    CustomLog logs/api_access.log api_log
    ErrorLog logs/api_error.log
</IfModule>

# ===================================================================
# Maintenance Mode
# ===================================================================

# Uncomment to enable maintenance mode
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{REQUEST_URI} !^/maintenance\.html$
#     RewriteRule ^(.*)$ /maintenance.html [R=503,L]
# </IfModule>

# ===================================================================
# IP Whitelist/Blacklist (Optional)
# ===================================================================

# Example: Allow only specific IPs
# <RequireAny>
#     Require ip 192.168.1.0/24
#     Require ip 10.0.0.0/8
# </RequireAny>

# Example: Block specific IPs
# <RequireAll>
#     Require not ip 192.168.1.100
#     Require not ip 10.0.0.50
# </RequireAll>
